# Configuration Amazon Invoice Downloader
# Copiez ce fichier vers .env et remplissez vos identifiants

# Identifiants Amazon (requis)
AMAZON_EMAIL=votre_email@example.com
AMAZON_PASSWORD=votre_mot_de_passe

# Chemin de téléchargement des factures (optionnel, défaut: ./factures)
DOWNLOAD_PATH=./factures

# Configuration Selenium (navigateur)
SELENIUM_BROWSER=firefox
SELENIUM_HEADLESS=false
SELENIUM_TIMEOUT=30
SELENIUM_MANUAL_MODE=false
SELENIUM_KEEP_BROWSER_OPEN=false

# Rester connecté (Amazon, Freebox, Free Mobile) entre les lancements :
# 1. Utilisez SELENIUM_BROWSER=firefox
# 2. Créez un profil Firefox dédié : ouvrez Firefox → about:profiles → "Créer un profil" (ex: "GetInvoices")
# 3. Indiquez le chemin du profil (affiché dans about:profiles), ex. :
#    Windows: FIREFOX_PROFILE_PATH=C:\Users\USERNAME\AppData\Roaming\Mozilla\Firefox\Profiles\xxxxx.GetInvoices
#    Linux:   FIREFOX_PROFILE_PATH=/home/user/.mozilla/firefox/xxxxx.GetInvoices
# Au premier lancement vous vous connectez ; les cookies sont enregistrés dans ce profil.
# Aux lancements suivants Firefox rouvre la même session (tant que le site ne l'a pas expirée).
# Ne pas ouvrir ce même profil dans une autre fenêtre Firefox pendant que le script tourne.
# FIREFOX_PROFILE_PATH=

# Chrome : profil dédié pour garder la session (recommandé pour FNAC)
# Créez un dossier dédié (ex: GetInvoicesChrome). Fermez Chrome avant de lancer le backend.
# Au 1er lancement : connectez-vous manuellement dans la fenêtre Chrome qui s'ouvre.
# Aux suivants : Chrome réutilise la session sauvegardée (cookies persistants).
# Windows: SELENIUM_CHROME_PROFILE_DIR=C:\Users\USERNAME\AppData\Local\GetInvoicesChrome
# SELENIUM_CHROME_PROFILE_DIR=

# Nombre maximum de factures par défaut (optionnel)
MAX_INVOICES=100

# Lancement : tout dans le terminal courant (ideal Cursor). false = 3 fenetres (backend + frontend separes)
START_SINGLE_WINDOW=true

# Freebox (optionnel) — identifiant espace abonné adsl.free.fr
# FREEBOX_LOGIN=votre_identifiant@free.fr
# FREEBOX_PASSWORD=votre_mot_de_passe

# Free Mobile (optionnel) — espace abonné mobile.free.fr (factures mobile)
# FREE_MOBILE_LOGIN=votre_identifiant_ou_numero
# FREE_MOBILE_PASSWORD=votre_mot_de_passe

# FNAC (optionnel) — espace client fnac.com (factures commandes)
# FNAC_LOGIN=votre_email@example.com
# FNAC_PASSWORD=votre_mot_de_passe

# Orange (optionnel) — espace client orange.fr (connexion manuelle via profil navigateur)
# ORANGE_LOGIN=votre_email@orange.fr
# ORANGE_INVOICES_URL=https://espace-client.orange.fr/factures

# Bouygues Telecom (optionnel) — espace client bouyguestelecom.fr
# BOUYGUES_LOGIN=votre_email_ou_numero
# BOUYGUES_PASSWORD=votre_mot_de_passe

# Decathlon (optionnel) — espace client decathlon.fr
# DECATHLON_LOGIN=votre_email@example.com
# DECATHLON_PASSWORD=votre_mot_de_passe

# Qobuz (optionnel) — espace client qobuz.com (factures abonnement et achats)
# QOBUZ_LOGIN=votre_email@example.com
# QOBUZ_PASSWORD=votre_mot_de_passe
